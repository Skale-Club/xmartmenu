# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Use the transaction pooler URL from Project Settings > Database > Connection string > Transaction (port 6543)
DATABASE_URL=postgresql://postgres.your-project-ref:YOUR-DB-PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres
# CLI credentials (for `supabase` CLI commands without interactive login)
SUPABASE_ACCESS_TOKEN=sbp_xxx
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_PROJECT_REF=your-project-ref

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com
SUPERADMIN_EMAILS=admin@example.com,other@example.com

# Public demo (/demo signs visitors into the sample restaurant's admin as owner)
# Optional: defaults are used if unset. The /demo route resets this account's
# password on every visit, so it is a sandbox owner, not a real credential.
DEMO_OWNER_EMAIL=demo-owner@xmartmenu.local
DEMO_OWNER_PASSWORD=XmartDemo2026!
DEFAULT_STAFF_PASSWORD=

# AI
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key
OPENAI_API_KEY=your-openai-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Dedicated HMAC key for Stripe Connect OAuth state (generate: openssl rand -hex 32).
# Falls back to STRIPE_WEBHOOK_SECRET if unset, but a dedicated key is recommended.
OAUTH_STATE_SECRET=
# Stripe Price ID for the AI Chat Addon ($20/month). Required only if the addon is sold.
STRIPE_CHAT_ADDON_PRICE_ID=
# Plan subscription Price IDs live in the DB (plans table) — run `npm run stripe:setup-plans`.

# Storage - optional S3 provider
STORAGE_PROVIDER=
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PUBLIC_URL_BASE=
STORAGE_S3_BUCKET_TENANT_ASSETS=xmartmenu-tenant-assets
STORAGE_S3_BUCKET_PRODUCT_IMAGES=xmartmenu-product-images

# GitHub seed image import - optional
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GH_PAT=

# Rate limiting (Upstash Redis) - optional; rate limiting fails OPEN until BOTH are set
# Create a database at https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Chat addon encryption - required only if the AI chat addon is enabled
# Must be 32 bytes; generate with: openssl rand -hex 32
CHAT_ADDON_ENCRYPTION_KEY=

# Error tracking & security-event alerting (Sentry) - optional; inert until set.
# Create a project at https://sentry.io and copy the DSN.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Only needed to upload source maps during the build (optional):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Xphere CRM Sync (v2.4) - optional; sync ships DARK until configured.
# ALL vars below are SERVER-ONLY — never prefix any of them with NEXT_PUBLIC_
# (these are secrets / internal config and must not reach the browser bundle).
# The sync stays a no-op until XPHERE_API_URL + XPHERE_API_KEY are set AND
# XPHERE_SYNC_ENABLED=true (the kill switch). Placeholders only here (gitleaks-safe).
XPHERE_API_URL=
XPHERE_API_KEY=
XPHERE_ORG_ID=e375f031-4d9a-42b1-9f3c-ade805650442
# QStash (Upstash) — durable delivery + signed worker callbacks.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Kill switch: leave empty/false to keep sync dark; set to `true` to activate.
XPHERE_SYNC_ENABLED=
# Pinned public worker URL for QStash signature verify — MUST match the publish
# URL exactly (never derive from req.url; the Coolify proxy rewrites host/scheme).
XPHERE_WORKER_URL=https://xmartmenu.skale.club/api/internal/xphere-sync
